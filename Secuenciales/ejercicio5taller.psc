Algoritmo ejercicio5taller
	Definir nomTrabajador Como Caracter
	Definir tarHora, horTrabajadas, total Como real
	Escribir "Bienvenido al sistema"
	Escribir "ingrese el nombre del trabajador"
	Leer nomTrabajador
	Escribir "ingrese la horas trabajadas de el empleado en el mes"
	Leer horTrabajadas
	
	tarHora <-7.959
	total <- tarHora * horTrabajadas
	
	Escribir "trabajador : ", nomTrabajador
	Escribir "la tarifa por hora estan a : ", total
FinAlgoritmo
