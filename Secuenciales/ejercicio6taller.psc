Algoritmo ejerciicio6taller
	Definir A, B, C, S como numero
	Escribir "ingrese lado A del triangulo en centimetros (con numero)"
	Leer A 
	Escribir "ingrese lado B del triangulo en centimetros (con numero)"
	Leer B
	Escribir "ingrese lado C del triangulo en centimetros (con numero)"
	Leer C
	
	S = A + B + C
	Escribir "el perimetro del triangulo es de  : ", S "cm"
FinAlgoritmo
